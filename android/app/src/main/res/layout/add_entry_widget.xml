<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/add_entry_widget_background"
    android:orientation="vertical"
    android:padding="12dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/widget_incoming_title"
            android:textColor="#FF143734"
            android:textSize="16sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/widget_add_entry_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:minHeight="40dp"
            android:minWidth="40dp"
            android:text="@string/widget_add_entry_symbol"
            android:textAllCaps="false" />
    </RelativeLayout>

    <TextView
        android:id="@+id/widget_incoming_empty"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/widget_incoming_empty"
        android:textColor="#CC143734"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/widget_incoming_item_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:maxLines="1"
        android:textColor="#FF143734"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_incoming_item_2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:textColor="#FF143734"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_incoming_item_3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:textColor="#FF143734"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/widget_incoming_item_4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:maxLines="1"
        android:textColor="#FF143734"
        android:textSize="14sp"
        android:visibility="gone" />
</LinearLayout>
